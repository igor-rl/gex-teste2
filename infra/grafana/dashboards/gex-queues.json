{
  "title": "GEX — Filas SQS",
  "uid": "gex-queues",
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "RAW — Entrada",
      "description": "Eventos aguardando validação",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 5 },
      "datasource": "Prometheus",
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "text": { "valueSize": 48 }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green",  "value": 0    },
              { "color": "yellow", "value": 100  },
              { "color": "red",    "value": 1000 }
            ]
          },
          "color": { "mode": "thresholds" },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "gex_queue_messages_available{queue=\"raw\"}",
          "legendFormat": "Disponíveis"
        },
        {
          "expr": "gex_queue_messages_inflight{queue=\"raw\"}",
          "legendFormat": "Em processamento"
        }
      ]
    },
    {
      "id": 2,
      "title": "VALID — Aguardando Entrega",
      "description": "Leads validados aguardando delivery",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 5 },
      "datasource": "Prometheus",
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "text": { "valueSize": 48 }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green",  "value": 0   },
              { "color": "yellow", "value": 50  },
              { "color": "red",    "value": 500 }
            ]
          },
          "color": { "mode": "thresholds" },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "gex_queue_messages_available{queue=\"valid\"}",
          "legendFormat": "Disponíveis"
        },
        {
          "expr": "gex_queue_messages_inflight{queue=\"valid\"}",
          "legendFormat": "Em processamento"
        }
      ]
    },
    {
      "id": 3,
      "title": "RESULTS — Aguardando Persistência",
      "description": "Resultados de delivery aguardando gravação no banco",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 5 },
      "datasource": "Prometheus",
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "text": { "valueSize": 48 }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green",  "value": 0   },
              { "color": "yellow", "value": 50  },
              { "color": "red",    "value": 500 }
            ]
          },
          "color": { "mode": "thresholds" },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "gex_queue_messages_available{queue=\"results\"}",
          "legendFormat": "Disponíveis"
        },
        {
          "expr": "gex_queue_messages_inflight{queue=\"results\"}",
          "legendFormat": "Em processamento"
        }
      ]
    },
    {
      "id": 4,
      "title": "DISCARDED — Descartados",
      "description": "Leads rejeitados na validação",
      "type": "stat",
      "gridPos": { "x": 0, "y": 5, "w": 8, "h": 5 },
      "datasource": "Prometheus",
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "text": { "valueSize": 48 }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green",  "value": 0  },
              { "color": "orange", "value": 10 },
              { "color": "red",    "value": 50 }
            ]
          },
          "color": { "mode": "thresholds" },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "gex_queue_messages_available{queue=\"discarded\"}",
          "legendFormat": "Disponíveis"
        },
        {
          "expr": "gex_queue_messages_inflight{queue=\"discarded\"}",
          "legendFormat": "Em processamento"
        }
      ]
    },
    {
      "id": 5,
      "title": "DLQ — Dead Letter Queue",
      "description": "⚠️ Mensagens que falharam em todas as tentativas",
      "type": "stat",
      "gridPos": { "x": 8, "y": 5, "w": 8, "h": 5 },
      "datasource": "Prometheus",
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "text": { "valueSize": 48 }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red",   "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "gex_queue_messages_available{queue=\"dlq\"}",
          "legendFormat": "Mensagens mortas"
        }
      ]
    },
    {
      "id": 6,
      "title": "Total em todas as filas",
      "type": "stat",
      "gridPos": { "x": 16, "y": 5, "w": 8, "h": 5 },
      "datasource": "Prometheus",
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "text": { "valueSize": 48 }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green",  "value": 0    },
              { "color": "yellow", "value": 500  },
              { "color": "red",    "value": 5000 }
            ]
          },
          "color": { "mode": "thresholds" },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "sum(gex_queue_messages_available)",
          "legendFormat": "Total disponíveis"
        },
        {
          "expr": "sum(gex_queue_messages_inflight)",
          "legendFormat": "Total em processamento"
        }
      ]
    },
    {
      "id": 7,
      "title": "Evolução das Filas ao longo do tempo",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 10, "w": 24, "h": 10 },
      "datasource": "Prometheus",
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        { "expr": "gex_queue_messages_available{queue=\"raw\"}",       "legendFormat": "raw" },
        { "expr": "gex_queue_messages_available{queue=\"valid\"}",     "legendFormat": "valid" },
        { "expr": "gex_queue_messages_available{queue=\"results\"}",   "legendFormat": "results" },
        { "expr": "gex_queue_messages_available{queue=\"discarded\"}", "legendFormat": "discarded" },
        { "expr": "gex_queue_messages_available{queue=\"dlq\"}",      "legendFormat": "dlq ⚠️" }
      ]
    },
    {
      "id": 8,
      "title": "Mensagens em processamento (inflight)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "datasource": "Prometheus",
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 20 }
        }
      },
      "targets": [
        { "expr": "gex_queue_messages_inflight{queue=\"raw\"}",   "legendFormat": "raw inflight" },
        { "expr": "gex_queue_messages_inflight{queue=\"valid\"}", "legendFormat": "valid inflight" }
      ]
    }
  ],
  "schemaVersion": 36,
  "tags": ["gex", "queues", "sqs"]
}